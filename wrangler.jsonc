{
  "name": "clocktower",
  "main": "src/index.js",
  "compatibility_date": "2026-07-09",
  "routes": [
    {
      "pattern": "clocktower.byron.land",
      "custom_domain": true
    }
  ],
  "assets": {
    // The path to the directory containing the `index.html` file to be served at `/`
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
